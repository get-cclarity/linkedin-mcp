{
    "name": "@cclarity-packages/cli",
    "version": "0.3.2",
    "description": "CClarity — init-only CLI to add @cclarity-packages/mcp to your IDE (like @dedot-ai/cli)",
    "license": "MIT",
    "main": "dist/index.js",
    "types": "dist/index.d.ts",
    "bin": {
        "cclarity": "dist/index.js"
    },
    "files": [
        "dist",
        "README.md"
    ],
    "scripts": {
        "build": "tsc",
        "clean": "rimraf dist",
        "prepublishOnly": "npm run clean && npm run build"
    },
    "engines": {
        "node": ">=18.0.0"
    },
    "publishConfig": {
        "access": "public"
    },
    "dependencies": {
        "@cclarity-packages/mcp": "file:../mcp",
        "@iarna/toml": "^2.2.5"
    },
    "devDependencies": {
        "@types/node": "^20.0.0",
        "rimraf": "^6.0.1",
        "typescript": "^5.4.0"
    },
    "keywords": [
        "cclarity",
        "mcp",
        "claude",
        "linkedin"
    ]
}
